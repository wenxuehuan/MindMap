                            AllowDrop="True"
                            SelectionChanged="DocumentsTabControl_SelectionChanged"
                            Drop="DocumentsTabControl_Drop">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel MinWidth="126"
                                       AllowDrop="True"
                                       PreviewMouseLeftButtonDown="TabHeader_PreviewMouseLeftButtonDown"
                                       MouseMove="TabHeader_MouseMove"
                                       Drop="TabHeader_Drop">
                                <DockPanel.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="{DynamicResource ShowInExplorer}" Tag="{Binding}" Click="ShowTabFileInExplorer_Click">
                                            <MenuItem.Icon><TextBlock Style="{StaticResource MenuIconStyle}" Text="&#xE838;" /></MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="{DynamicResource CloseCurrentTab}" Tag="{Binding}" Click="CloseTabMenuItem_Click">
                                            <MenuItem.Icon><TextBlock Style="{StaticResource MenuIconStyle}" Text="&#xE711;" /></MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </DockPanel.ContextMenu>
                                <Button DockPanel.Dock="Right"
                                        Content="×"
                                        Style="{StaticResource TabCloseButtonStyle}"
                                        Margin="8,0,0,0"
                                        Tag="{Binding}"
