                        <Button x:Name="RedoToolbarButton" Content="&#xE7A6;" ToolTip="{DynamicResource Redo}" AutomationProperties.Name="{DynamicResource Redo}" Click="Redo_Click" Style="{StaticResource ToolbarIconButtonStyle}" />
