                                        </Button>
                                    </WrapPanel>

                                    <TextBlock Text="{DynamicResource TextColor}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,6" />
                                    <WrapPanel>
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#0F172A" Tag="TextColor|#0F172A" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#1D4ED8" Tag="TextColor|#1D4ED8" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#15803D" Tag="TextColor|#15803D" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#B45309" Tag="TextColor|#B45309" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#BE185D" Tag="TextColor|#BE185D" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#FFFFFF" Tag="TextColor|#FFFFFF" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Tag="TextColor" Click="ColorPickerButton_Click" ToolTip="{DynamicResource CustomColor}">
                                            <Grid Width="18" Height="18">
                                                <Grid.RowDefinitions><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions>
                                                <Border Background="#2563EB" />
                                                <Border Grid.Column="1" Background="#16A34A" />
                                                <Border Grid.Row="1" Background="#D97706" />
                                                <Border Grid.Row="1" Grid.Column="1" Background="#DB2777" />
                                            </Grid>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Header="{DynamicResource Font}" IsExpanded="True" Margin="0,0,0,8">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="{DynamicResource FontFamily}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                                    <ComboBox x:Name="FontFamilyComboBox" SelectionChanged="FontFamilyComboBox_SelectionChanged">
                                        <ComboBoxItem Content="微软雅黑" Tag="Microsoft YaHei UI" />
                                        <ComboBoxItem Content="等线" Tag="DengXian" />
                                        <ComboBoxItem Content="宋体" Tag="SimSun" />
                                        <ComboBoxItem Content="黑体" Tag="SimHei" />
                                        <ComboBoxItem Content="Consolas" Tag="Consolas" />
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource FontSize}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,4" />
                                    <ComboBox x:Name="FontSizeComboBox" SelectionChanged="FontSizeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="12" Tag="12" />
                                        <ComboBoxItem Content="14" Tag="14" />
                                        <ComboBoxItem Content="16" Tag="16" />
                                        <ComboBoxItem Content="18" Tag="18" />
                                        <ComboBoxItem Content="20" Tag="20" />
                                        <ComboBoxItem Content="24" Tag="24" />
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource FontWeight}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,4" />
                                    <ComboBox x:Name="FontWeightComboBox" SelectionChanged="FontWeightComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource Normal}" Tag="Normal" />
                                        <ComboBoxItem Content="{DynamicResource SemiBold}" Tag="SemiBold" />
                                        <ComboBoxItem Content="{DynamicResource Bold}" Tag="Bold" />
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource FontStyle}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,4" />
                                    <ComboBox x:Name="FontStyleComboBox" SelectionChanged="FontStyleComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource StyleNormal}" Tag="Normal" />
                                        <ComboBoxItem Content="{DynamicResource Italic}" Tag="Italic" />
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource TextAlignment}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,4" />
                                    <ComboBox x:Name="TextAlignmentComboBox" SelectionChanged="TextAlignmentComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource AlignLeft}" Tag="Left" />
                                        <ComboBoxItem Content="{DynamicResource AlignCenter}" Tag="Center" />
                                        <ComboBoxItem Content="{DynamicResource AlignRight}" Tag="Right" />
                                    </ComboBox>
                                </StackPanel>
                            </Expander>

                            <Expander Header="{DynamicResource Appearance}" IsExpanded="True" Margin="0,0,0,8">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="{DynamicResource Shape}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                                    <ComboBox x:Name="ShapeComboBox" SelectionChanged="ShapeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource RoundedRectangle}" Tag="RoundedRectangle" />
                                        <ComboBoxItem Content="{DynamicResource Rectangle}" Tag="Rectangle" />
                                        <ComboBoxItem Content="{DynamicResource Pill}" Tag="Pill" />
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource BorderThickness}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,4" />
                                    <ComboBox x:Name="BorderThicknessComboBox" SelectionChanged="BorderThicknessComboBox_SelectionChanged">
                                        <ComboBoxItem Content="1 px" Tag="1" />
                                        <ComboBoxItem Content="2 px" Tag="2" />
                                        <ComboBoxItem Content="3 px" Tag="3" />
                                    </ComboBox>
                                </StackPanel>
                            </Expander>

                            <Expander Header="{DynamicResource Connector}" IsExpanded="True" Margin="0,0,0,8">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="{DynamicResource LineColor}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,6" />
                                    <WrapPanel>
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#94A3B8" Tag="ConnectorColor|#94A3B8" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#2563EB" Tag="ConnectorColor|#2563EB" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#16A34A" Tag="ConnectorColor|#16A34A" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#D97706" Tag="ConnectorColor|#D97706" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#DB2777" Tag="ConnectorColor|#DB2777" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#7C3AED" Tag="ConnectorColor|#7C3AED" Click="ColorSwatch_Click" />
                                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Tag="ConnectorColor" Click="ColorPickerButton_Click" ToolTip="{DynamicResource CustomColor}">
                                            <Grid Width="18" Height="18">
                                                <Grid.RowDefinitions><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions>
                                                <Border Background="#2563EB" />
                                                <Border Grid.Column="1" Background="#16A34A" />
                                                <Border Grid.Row="1" Background="#D97706" />
                                                <Border Grid.Row="1" Grid.Column="1" Background="#DB2777" />
                                            </Grid>
                                        </Button>
                                    </WrapPanel>

                                    <TextBlock Text="{DynamicResource LineThickness}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,4" />
                                    <ComboBox x:Name="ConnectorThicknessComboBox" SelectionChanged="ConnectorThicknessComboBox_SelectionChanged">
                                        <ComboBoxItem Content="1 px" Tag="1" />
                                        <ComboBoxItem Content="2 px" Tag="2" />
                                        <ComboBoxItem Content="3 px" Tag="3" />
                                        <ComboBoxItem Content="4 px" Tag="4" />
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource LineStyle}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,4" />
                                    <ComboBox x:Name="ConnectorDashStyleComboBox" SelectionChanged="ConnectorDashStyleComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource Solid}" Tag="Solid" />
                                        <ComboBoxItem Content="{DynamicResource Dash}" Tag="Dash" />
                                        <ComboBoxItem Content="{DynamicResource Dot}" Tag="Dot" />
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource LineRouting}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,4" />
                                    <ComboBox x:Name="ConnectorShapeComboBox" SelectionChanged="ConnectorShapeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource Curve}" Tag="Curve" />
                                        <ComboBoxItem Content="{DynamicResource Straight}" Tag="Straight" />
                                        <ComboBoxItem Content="{DynamicResource Elbow}" Tag="Elbow" />
                                        <ComboBoxItem Content="{DynamicResource AngleBracket}" Tag="AngleBracket" />
                                        <ComboBoxItem Content="{DynamicResource SquareBracket}" Tag="SquareBracket" />
                                    </ComboBox>

                                    <TextBlock Text="{DynamicResource Arrow}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,10,0,4" />
                                    <ComboBox x:Name="ConnectorArrowStyleComboBox" SelectionChanged="ConnectorArrowStyleComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource None}" Tag="None" />
                                        <ComboBoxItem Content="{DynamicResource ArrowStart}" Tag="Start" />
                                        <ComboBoxItem Content="{DynamicResource ArrowEnd}" Tag="End" />
                                        <ComboBoxItem Content="{DynamicResource ArrowBoth}" Tag="Both" />
                                    </ComboBox>
                                </StackPanel>
                            </Expander>
                            </StackPanel>

                            <Expander Header="{DynamicResource MindMapInfo}" IsExpanded="True">
                                <TextBlock x:Name="StatsText" Margin="0,8,0,0" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

        <Popup x:Name="ColorPickerPopup"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade">
            <Border Background="{DynamicResource ControlBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Width="300">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18" />
                </Border.Effect>
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <Border x:Name="PopupColorPreview"
                                DockPanel.Dock="Left"
                                Width="44"
                                Height="32"
                                BorderBrush="{DynamicResource TextMutedBrush}"
                                BorderThickness="1"
                                Margin="0,0,10,0" />
                        <TextBlock x:Name="PopupColorTitle"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </DockPanel>

                    <WrapPanel Margin="0,0,0,10">
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#FFFFFF" Tag="#FFFFFF" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#0F172A" Tag="#0F172A" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#CBD5E1" Tag="#CBD5E1" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#DBEAFE" Tag="#DBEAFE" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#DCFCE7" Tag="#DCFCE7" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#FEF3C7" Tag="#FEF3C7" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#FCE7F3" Tag="#FCE7F3" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#EDE9FE" Tag="#EDE9FE" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#2563EB" Tag="#2563EB" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#16A34A" Tag="#16A34A" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#D97706" Tag="#D97706" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#DB2777" Tag="#DB2777" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#7C3AED" Tag="#7C3AED" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#1D4ED8" Tag="#1D4ED8" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#15803D" Tag="#15803D" Click="ColorPickerPreset_Click" />
                        <Button Style="{StaticResource ColorSwatchButtonStyle}" Background="#B45309" Tag="#B45309" Click="ColorPickerPreset_Click" />
                    </WrapPanel>

                    <TextBlock Text="Hex" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,4" />
                    <TextBox x:Name="ColorHexBox" Padding="7,4" TextChanged="ColorHexBox_TextChanged" />

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="54" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="30" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="R" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                        <Slider x:Name="ColorRedSlider" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1"
                                IsSnapToTickEnabled="True" ValueChanged="ColorRgbSlider_ValueChanged" Margin="0,0,10,0" />
                        <TextBox x:Name="ColorRedBox" Grid.Row="0" Grid.Column="2" Padding="7,4" TextChanged="ColorRgbBox_TextChanged" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="G" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                        <Slider x:Name="ColorGreenSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1"
                                IsSnapToTickEnabled="True" ValueChanged="ColorRgbSlider_ValueChanged" Margin="0,0,10,0" />
                        <TextBox x:Name="ColorGreenBox" Grid.Row="1" Grid.Column="2" Padding="7,4" TextChanged="ColorRgbBox_TextChanged" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="B" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                        <Slider x:Name="ColorBlueSlider" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1"
                                IsSnapToTickEnabled="True" ValueChanged="ColorRgbSlider_ValueChanged" Margin="0,0,10,0" />
                        <TextBox x:Name="ColorBlueBox" Grid.Row="2" Grid.Column="2" Padding="7,4" TextChanged="ColorRgbBox_TextChanged" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="{DynamicResource Ok}" Margin="0,0,8,0" Click="ColorPickerOk_Click" Style="{StaticResource ColorPickerActionButtonStyle}" />
                        <Button Content="{DynamicResource Cancel}" Click="ColorPickerCancel_Click" Style="{StaticResource ColorPickerActionButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
        </Grid>
    </DockPanel>
</Window>

