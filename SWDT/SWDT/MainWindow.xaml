                                <Thumb Grid.Row="2" Grid.Column="2" Cursor="SizeNWSE" Tag="Right, Bottom" Style="{StaticResource NodeNoteResizeThumbStyle}" DragDelta="NodeNoteResizeThumb_DragDelta" />
