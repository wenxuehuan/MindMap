                          MouseLeftButtonUp="MindMapCanvas_MouseLeftButtonUp"
                          MouseRightButtonDown="MindMapCanvas_MouseRightButtonDown"
                          MouseRightButtonUp="MindMapCanvas_MouseRightButtonUp"
                          MouseMove="MindMapCanvas_MouseMove"
                          MouseWheel="MindMapCanvas_MouseWheel">
                        <Rectangle x:Name="CanvasBackground"
                                   IsHitTestVisible="False" />
                        <Canvas x:Name="MindMapCanvas">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1" />
                                    <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0" />
                                </TransformGroup>
                            </Canvas.RenderTransform>
                        </Canvas>
                        <Canvas x:Name="CanvasOverlay"
                                IsHitTestVisible="False">
                            <Rectangle x:Name="SelectionRectangle"
