                        <Button Content="&#xECC8;" ToolTip="{DynamicResource AddChildShortcut}" AutomationProperties.Name="{DynamicResource AddChild}" Click="AddChild_Click" Style="{StaticResource ToolbarIconButtonStyle}" />
                        <Button Content="&#xE8B0;" ToolTip="{DynamicResource AddSiblingShortcut}" AutomationProperties.Name="{DynamicResource AddSibling}" Click="AddSibling_Click" Style="{StaticResource ToolbarIconButtonStyle}" />
                        <Button x:Name="AddSummaryToolbarButton" Content="&#xE9D2;" ToolTip="{DynamicResource AddSummary}" AutomationProperties.Name="{DynamicResource AddSummary}" Click="AddSummary_Click" Style="{StaticResource ToolbarIconButtonStyle}" />
                        <Button x:Name="AddConnectionToolbarButton" Content="&#xE71B;" ToolTip="{DynamicResource AddConnection}" AutomationProperties.Name="{DynamicResource AddConnection}" Click="AddConnection_Click" Style="{StaticResource ToolbarIconButtonStyle}" />
                        <Button Content="&#xE74D;" ToolTip="{DynamicResource DeleteNode}" AutomationProperties.Name="{DynamicResource DeleteNode}" Click="DeleteNode_Click" Style="{StaticResource ToolbarIconButtonStyle}" />
                        <Border Width="1" Height="22" Background="{DynamicResource PanelBorderBrush}" Margin="4,4,8,4" />
                        <Button Content="&#xE8A9;" ToolTip="{DynamicResource AutoLayout}" AutomationProperties.Name="{DynamicResource AutoLayout}" Click="AutoLayout_Click" Style="{StaticResource ToolbarIconButtonStyle}" />
                        <Button Content="&#xE72C;" ToolTip="{DynamicResource ResetView}" AutomationProperties.Name="{DynamicResource ResetView}" Click="ResetView_Click" Style="{StaticResource ToolbarIconButtonStyle}" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </DockPanel>

        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource TopBarBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1,0,0,0" Padding="8,2">
            <TextBlock x:Name="StatusText" Text="{DynamicResource Ready}" />
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightSidebarColumn" Width="300" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="12,12,10,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TabControl x:Name="DocumentsTabControl"
                            Grid.Row="0"
                            Style="{StaticResource DocumentTabControlStyle}"
